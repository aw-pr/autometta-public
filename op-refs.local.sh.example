#!/usr/bin/env bash
# op-refs.local.sh — GITIGNORED override for the real 1Password references.
#
# Recommended location (machine-wide, works for both the dev checkout and
# the brew-installed CLI):
#
#   mkdir -p ~/.config/autometta
#   cp op-refs.local.sh.example ~/.config/autometta/op-refs.local.sh
#   chmod 600 ~/.config/autometta/op-refs.local.sh
#
# Alternative locations (in resolution order, first wins):
#   1. $AUTOMETTA_LOCAL_REFS  (explicit env var override)
#   2. ~/.config/autometta/op-refs.local.sh  (XDG, recommended)
#   3. <repo-root>/op-refs.local.sh  (next to op-refs.sh; dev checkout only —
#      not visible to the brew-installed CLI)
#
# Find a reference in 1Password desktop: right-click an item -> Copy Secret
# Reference. Or via the CLI:
#   op item get "<ItemName>" --vault "<VaultName>" --format=json | jq '.fields[].label'

export OP_REF_OPENAI_API_KEY="op://YOUR_VAULT/OpenAI/credential"
export OP_REF_ANTHROPIC_API_KEY="op://YOUR_VAULT/Anthropic/credential"

# Leave commented unless you store the Claude OAuth token in 1Password as well.
# This is the env-var route for Claude Pro / Max OAuth via op-fetch; for the
# default file-based session at ~/.config/claude/ it is not needed.
# export OP_REF_CLAUDE_CODE_OAUTH_TOKEN="op://YOUR_VAULT/Claude-OAuth/credential"
