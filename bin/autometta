#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
autometta_root="${AUTOMETTA_ROOT:-$(cd "$script_dir/.." && pwd)}"

usage() {
  cat <<'USAGE'
Usage:
  autometta --version
  autometta init-host
  autometta init [repo-path]
  autometta subscribe [repo-path]
  autometta add-stage <repo-path> <stage-card-path>
  autometta status
  autometta attach [repo-path] [--dry-run]
  autometta tick [--repair|--reset-halt]
  autometta check-deps
  autometta dashboard [--open]
  autometta install-launchagent <repo-path> [--interval N]
  autometta uninstall-launchagent <repo-path>
  autometta install-homebrew-local [--dry-run]
  autometta auth status
  autometta auth check <codex|claude>
  autometta panel <stage-id> [repo-path]
USAGE
}

run_script() {
  local script_name="$1"
  shift
  local script_path="$autometta_root/scripts/$script_name"
  if [[ ! -x "$script_path" ]]; then
    printf 'MISSING %s\n' "$script_path" >&2
    exit 1
  fi
  "$script_path" "$@"
}

command_name="${1:-}"
if [[ -z "$command_name" ]]; then
  usage
  exit 1
fi
shift

case "$command_name" in
  --help|-h|help)
    usage
    ;;
  --version|version)
    version_file="$autometta_root/VERSION"
    if [[ -s "$version_file" ]]; then
      printf 'autometta %s\n' "$(head -n 1 "$version_file" | tr -d '[:space:]')"
    elif git -C "$autometta_root" rev-parse --short HEAD >/dev/null 2>&1; then
      printf 'autometta %s\n' "$(git -C "$autometta_root" rev-parse --short HEAD)"
    else
      printf 'autometta local\n'
    fi
    ;;
  init-host)
    run_script init-host.sh "$@"
    ;;
  init)
    repo_path="${1:-.}"
    if [[ $# -gt 1 ]]; then
      printf 'usage: autometta init [repo-path]\n' >&2
      exit 1
    fi
    run_script init-host.sh
    run_script subscribe-repo.sh "$repo_path"
    run_script attach.sh --ensure "$repo_path"
    printf '\nNext: review and commit the generated repo setup before running autometta tick.\n'
    printf 'Typical files: .gitignore, state/state.yaml, state/budget.json; .autometta.local.yaml stays gitignored.\n'
    ;;
  subscribe)
    repo_path="${1:-.}"
    if [[ $# -gt 1 ]]; then
      printf 'usage: autometta subscribe [repo-path]\n' >&2
      exit 1
    fi
    run_script subscribe-repo.sh "$repo_path"
    ;;
  add-stage)
    if [[ $# -ne 2 ]]; then
      printf 'usage: autometta add-stage <repo-path> <stage-card-path>\n' >&2
      exit 1
    fi
    run_script add-stage.sh "$@"
    ;;
  status)
    run_script status.sh "$@"
    ;;
  attach)
    run_script attach.sh "$@"
    ;;
  tick)
    run_script tick.sh "$@"
    ;;
  check-deps)
    run_script check-deps.sh "$@"
    ;;
  dashboard)
    run_script dashboard.sh "$@"
    ;;
  install-launchagent)
    if [[ $# -lt 1 ]]; then
      printf 'usage: autometta install-launchagent <repo-path> [--interval N]\n' >&2
      exit 1
    fi
    run_script install-launchagent.sh "$@"
    ;;
  uninstall-launchagent)
    if [[ $# -ne 1 ]]; then
      printf 'usage: autometta uninstall-launchagent <repo-path>\n' >&2
      exit 1
    fi
    run_script uninstall-launchagent.sh "$@"
    ;;
  install-homebrew-local)
    run_script install-homebrew-local.sh "$@"
    ;;
  auth)
    run_script auth.sh "$@"
    ;;
  panel)
    if [[ $# -lt 1 ]]; then
      printf 'usage: autometta panel <stage-id> [repo-path]\n' >&2
      exit 1
    fi
    stage_id_arg="$1"
    repo_path_arg="${2:-.}"
    shift $#
    # Find the card for the given stage-id using the stage_card_globs from
    # .autometta.local.yaml, falling back to examples/self-host/ convention.
    card_file=""
    for pattern in \
      "${repo_path_arg}/examples/self-host/${stage_id_arg}.md" \
      "${repo_path_arg}/examples/**/${stage_id_arg}.md" \
      "${repo_path_arg}/${stage_id_arg}.md"; do
      candidate="$(ls "${pattern}" 2>/dev/null | head -n1 || true)"
      if [[ -f "${candidate:-}" ]]; then
        card_file="$candidate"
        break
      fi
    done
    if [[ -z "$card_file" ]]; then
      printf 'panel: stage card not found for stage-id: %s\n' "$stage_id_arg" >&2
      printf '  searched under: %s\n' "$repo_path_arg" >&2
      exit 1
    fi
    panel_script="$autometta_root/scripts/spawn-verifier-panel.sh"
    if [[ ! -x "$panel_script" ]]; then
      printf 'panel: spawn-verifier-panel.sh not found at %s\n' "$panel_script" >&2
      exit 1
    fi
    exec "$panel_script" "$card_file" "$repo_path_arg" --read-only
    ;;
  *)
    printf 'unknown command: %s\n' "$command_name" >&2
    usage >&2
    exit 1
    ;;
esac
