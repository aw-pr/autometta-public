# Copy to .autometta.local.yaml (gitignored under *.local) and fill in
# the per-repo manifest. This file is the documented template; the real
# file stays out of the tree.

version: 1

# Optional override of where the autometta repo lives. Defaults to the
# value detected by subscribe-repo.sh at registration time.
# autometta_root: /Users/yourname/repos/autometta

state_dir: state

stage_card_globs:
  - docs/stages/*.md
  - examples/self-host/*.md

templates_mode: upstream

# ---------------------------------------------------------------------------
# Auth routes (per family). Default for both is `subscription` (OAuth /
# ChatGPT or Claude Pro sessions); flip to `api` to bill via API key.
#
# This file only controls WHICH route. The op:// references themselves live
# in op-refs.sh (committed placeholders) + op-refs.local.sh (gitignored
# real refs). See the auth-route-security skill for the full pattern.
#
# Override at dispatch time without editing this file:
#   AUTOMETTA_CODEX_MODE=api  autometta tick
#   AUTOMETTA_CLAUDE_MODE=api autometta tick
#
# The dispatch path is always op-fetch -> child (env -i + allowlist), so
# subscription mode also gets a sanitised env that strips any inherited
# OPENAI_API_KEY / ANTHROPIC_API_KEY from the parent shell. api mode fails
# closed if op-fetch is missing or the matching OP_REF_* points at the
# YOUR_VAULT placeholder.
# ---------------------------------------------------------------------------

auth:
  codex:
    mode: subscription
    # mode: api    # requires OP_REF_OPENAI_API_KEY set in op-refs.local.sh
  claude:
    mode: subscription
    # mode: api    # requires OP_REF_ANTHROPIC_API_KEY set in op-refs.local.sh
