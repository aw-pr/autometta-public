# Copy to .publish-guard.local at the repo root (gitignored). Personal/machine
# patterns ONLY live here — never in committed code. Edit the values, then the
# pre-commit and pre-push hooks read them.

# Extended-regex alternation of strings that must never be committed:
# your home path, your real 1Password vault(s), your username/email.
GUARD_PATTERNS='/Users/YOURNAME|/home/YOURNAME|op://YOUR_VAULT|YOURNAME@'

# Public repo: a fragment of its remote URL, and the only branch allowed there.
GUARD_PUBLIC_URL_MATCH='your-org/your-repo'
GUARD_PUBLIC_BRANCH='main'
