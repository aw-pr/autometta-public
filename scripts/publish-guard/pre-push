#!/usr/bin/env bash
# publish-guard pre-push: on the PUBLIC remote, allow only the public branch.
# Keeps dev/feature/temp branches off the public repo. Private remotes are
# unrestricted (backups). Config from gitignored .publish-guard.local.
# Override once with: git push --no-verify
remote_name="$1"
remote_url="$2"
root="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
cfg="$root/.publish-guard.local"
[ -f "$cfg" ] && { # shellcheck disable=SC1090
  source "$cfg"; }
pub="${GUARD_PUBLIC_URL_MATCH:-}"
branch="${GUARD_PUBLIC_BRANCH:-main}"
[ -z "$pub" ] && exit 0
case "$remote_url" in
  *"$pub"*) : ;;          # public remote — restricted below
  *) exit 0 ;;            # any other remote (private backup) — unrestricted
esac
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    "refs/heads/$branch"|"") : ;;
    *)
      echo "publish-guard: '$remote_ref' blocked on PUBLIC remote '$remote_name'." >&2
      echo "          Only '$branch' is public. Push elsewhere private, or" >&2
      echo "          override intentionally with: git push --no-verify" >&2
      exit 1 ;;
  esac
done
exit 0
