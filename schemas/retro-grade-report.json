{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autometta.local/schemas/retro-grade-report.json",
  "title": "retro-grade report frontmatter",
  "description": "Frontmatter contract for memory/retro-grade-<YYYY-MM-DD>.md. The Markdown body lists only stages whose retro grade disagreed with the original.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "date",
    "type",
    "batch_id",
    "batch",
    "model",
    "stage_count",
    "drift_count",
    "input_tokens",
    "output_tokens",
    "total_tokens"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "type": {
      "const": "retro-grade-report"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "batch": {
      "const": true
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "stage_count": {
      "type": "integer",
      "minimum": 1
    },
    "drift_count": {
      "type": "integer",
      "minimum": 0
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    }
  }
}
